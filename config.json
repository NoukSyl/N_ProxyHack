{
  "server": {
    "http_port": 3000,
    "https_port": 3443,
    "enable_https": false,
    "ssl": {
      "cert": "./certs/server.crt",
      "key": "./certs/server.key"
    }
  },
  "logging": {
    "level": "info",
    "log_dir": "./logs",
    "log_requests": true,
    "log_errors": true,
    "max_file_size": "10m",
    "max_files": 5
  },
  "routes": [
    {
      "context": "/api",
      "target_env": "TARGET_API",
      "description": "Route /api/* → set TARGET_API in Railway env vars",
      "change_origin": true,
      "path_rewrite": { "^/api": "" }
    },
    {
      "context": "/static",
      "target_env": "TARGET_STATIC",
      "description": "Route /static/* → set TARGET_STATIC in Railway env vars",
      "change_origin": true
    },
    {
      "context": "/",
      "target_env": "TARGET_APP",
      "description": "Catch-all → set TARGET_APP in Railway env vars",
      "change_origin": true
    }
  ],
  "rate_limit": {
    "enabled": false,
    "window_ms": 60000,
    "max_requests": 100
  }
}
